CORPSCOUT_DATABASE_URL=postgresql://corpscout:corpscout@postgres:5432/corpscout?sslmode=disable
DAGSTER_MIGRATIONS_DATABASE_URL=postgresql://corpscout:corpscout@postgres:5432/corpscout?sslmode=disable&x-migrations-table=dagster_schema_migrations
MOCK_HOST_DATABASE_URL=postgresql://corpscout:corpscout@localhost:15432/corpscout?sslmode=disable

DAGSTER_PORT=3001
DAGSTER_HOME_DIR=./.dagster_home_mock
MOCK_POSTGRES_PORT=15432
TRANSLATION_SERVICE_PORT=18095
CRAWL_SERVICE_PORT=18096

DAGSTER_IMAGE=corpscout-dagster:mock
TRANSLATION_SERVICE_IMAGE=corpscout-translation-service:mock
CRAWL_SERVICE_IMAGE=corpscout-crawl-service:mock
MIGRATE_IMAGE=migrate/migrate

BRREG_BULK_FIXTURE_PATH=/fixtures/brreg_raw_records_1000.json.gz
BRREG_FX_PROVIDER=mock
BRREG_FX_RATE_DATE=

TRANSLATION_MOCK_ENABLED=true
TRANSLATION_DEFAULT_PROVIDER=mock
TRANSLATION_DEFAULT_MODEL=mock-model
BRREG_TRANSLATION_PROVIDER=mock
BRREG_TRANSLATION_MODEL=mock-model
BRREG_TRANSLATION_PROMPT_VERSION=v1
TRANSLATION_SERVICE_URL=http://translation-service:8095
TRANSLATION_SERVICE_TIMEOUT_SECONDS=30

CRAWL_SERVICE_MODE=mock
CRAWL_SERVICE_MOCK_ENABLED=true
CRAWL_SERVICE_URL=http://crawl-service:8096
CRAWL_SERVICE_TIMEOUT_SECONDS=30

MOCK_SEED=brreg-e2e-v1
MOCK_PROFILE=mixed

BRREG_RAW_RECORD_BATCH_SIZE=500
BRREG_RAW_RECORD_LIMIT=1000
BRREG_TRANSLATION_BATCH_SIZE=1
BRREG_TRANSLATION_MAX_BATCHES_PER_RUN=0
BRREG_TRANSLATION_MAX_PARALLEL_TASKS=50
BRREG_DOMAIN_RESULT_BATCH_SIZE=25
BRREG_DOMAIN_RESULT_MAX_BATCHES_PER_RUN=0
BRREG_DOMAIN_RESULT_MAX_PARALLEL_TASKS=25
BRREG_CURRENCY_RESULT_BATCH_SIZE=100
BRREG_CURRENCY_RESULT_MAX_BATCHES_PER_RUN=0
BRREG_CURRENCY_RESULT_MAX_PARALLEL_TASKS=50
BRREG_ENHANCED_RECORD_BATCH_SIZE=1000
