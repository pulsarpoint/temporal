# Corpscout Postgres connection used by Dagster assets.
CORPSCOUT_DATABASE_URL=postgresql://corpscout:corpscout@127.0.0.1:5432/corpscout

# Optional limiter for local BRREG bulk smoke runs.
BRREG_MAX_RECORDS=

# Dagster webserver listens on host networking in docker-compose.
DAGSTER_PORT=3000

# Local host folder mounted into the containers as DAGSTER_HOME.
DAGSTER_HOME_DIR=./.dagster_home
