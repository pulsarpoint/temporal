# Corpscout Postgres connection used by Dagster assets.
# Docker Compose maps companycollect to 100.85.212.113 for containers.
CORPSCOUT_DATABASE_URL=postgresql://corpscout:corpscout@companycollect:5432/corpscout?sslmode=disable

# Migration-only DSN. Dagster uses a separate golang-migrate tracking table so
# it does not collide with Corpscout application migrations.
DAGSTER_MIGRATIONS_DATABASE_URL=postgresql://corpscout:corpscout@companycollect:5432/corpscout?sslmode=disable&x-migrations-table=dagster_schema_migrations

# Host port published by docker-compose for the Dagster web UI.
DAGSTER_PORT=3000

# Translation service runs in the same docker-compose project as Dagster.
TRANSLATION_SERVICE_PORT=8095
TRANSLATION_SERVICE_IMAGE=ghcr.io/pulsarpoint/corpscout-translation-service:latest
TRANSLATION_DEFAULT_PROVIDER=local
TRANSLATION_DEFAULT_MODEL=qwen3:6b
TRANSLATION_PROVIDER_LOCAL_BASE_URL=http://100.77.62.33:8888
# Local LLM does not require a password/API key.
# TRANSLATION_PROVIDER_LOCAL_API_KEY=

# Crawl service hosts BRREG domain discovery and crawl/LLM analysis APIs.
CRAWL_SERVICE_PORT=8096
CRAWL_SERVICE_IMAGE=ghcr.io/pulsarpoint/corpscout-crawl-service:latest
CRAWL_SERVICE_LLM_MODEL=qwen3:6b
CRAWL_SERVICE_LLM_BASE_URL=http://100.77.62.33:8888
CRAWL_SERVICE_LLM_API_KEY=
# Prefer this for Docker secrets instead of putting the key directly in env.
# CRAWL_SERVICE_LLM_API_KEY_FILE=/run/secrets/crawl_service_llm_api_key
# Default search provider order when a request does not override search_provider.
# Keep DuckDuckGo as production default; request-level overrides can use yandex
# or comma-separated chains such as duckduckgo,yandex.
DOMAIN_SEARCH_PROVIDERS=duckduckgo
# Optional domain-search tuning. Excluded LLM-extracted candidate domains stay
# in artifacts with metadata.excluded=true, but are not crawled for final
# ownership verification.
# DOMAIN_SEARCH_EXCLUDED_DOMAINS=proff.no,gulesider.no,brreg.no
# DOMAIN_SEARCH_EXTRA_EXCLUDED_DOMAINS=
# DOMAIN_SEARCH_ALLOWED_DOMAINS=

# Local host folder mounted into the containers as DAGSTER_HOME.
DAGSTER_HOME_DIR=./.dagster_home

# BRREG maintenance cutoff for recovering stale runs after interrupted workers.
BRREG_STALE_RUN_CLEANUP_MINUTES=30

# BRREG domain enrichment runs independent signals with different speeds.
BRREG_DOMAIN_WEBSITE_FIELD_BATCH_SIZE=5000
BRREG_DOMAIN_DUCKDUCKGO_BATCH_SIZE=10
BRREG_DOMAIN_CRTSH_BATCH_SIZE=10
BRREG_DOMAIN_WIKIDATA_BATCH_SIZE=25
BRREG_DOMAIN_WEB_SEARCH_LLM_BATCH_SIZE=10
BRREG_DOMAIN_PROPOSAL_BATCH_SIZE=500
BRREG_DOMAIN_MAX_BATCHES_PER_RUN=20

# Optional fixed ECB date for BRREG capital conversion. Empty means latest ECB rate.
# BRREG_FX_RATE_DATE=2026-05-21

# OpenAI-compatible LLM used by brreg_domain_web_search_llm_job.
DOMAIN_LLM_BASE_URL=https://api.deepseek.com
DOMAIN_LLM_MODEL=deepseek-v4-flash
DOMAIN_LLM_PROMPT_VERSION=v1
# DOMAIN_LLM_API_KEY=

# crawl4ai/Playwright browser settings for web-search domain discovery.
# Headed mode needs a DISPLAY/Xvfb-capable runtime; production should stay headless.
DOMAIN_CRAWLER_BROWSER_TYPE=chromium
DOMAIN_CRAWLER_CHROME_CHANNEL=chromium
DOMAIN_CRAWLER_HEADLESS=true
DOMAIN_CRAWLER_LIGHT_MODE=true

# Docker image used by Makefile migration targets.
MIGRATE_IMAGE=migrate/migrate
