# Corpscout Crawl Service configuration.
#
# Copy this file to .env for local development. In Docker/production, pass the
# same variables through docker compose or the process environment.

# Required OpenAI-compatible LLM endpoint used by the direct page analysis
# layer. Crawling and LLM reasoning are separated: crawl4ai returns markdown
# and links, then this model scores search links and verifies candidate sites.
CRAWL_SERVICE_LLM_MODEL=qwen3:6b
CRAWL_SERVICE_LLM_BASE_URL=http://100.77.62.33:8888

# Optional. Leave empty for local LLM endpoints that do not require a key.
CRAWL_SERVICE_LLM_API_KEY=
# Prefer this for Docker secrets instead of putting the key directly in env.
# CRAWL_SERVICE_LLM_API_KEY_FILE=/run/secrets/crawl_service_llm_api_key

# Disable reasoning/thinking mode for models that support chat_template_kwargs.
CRAWL_SERVICE_DISABLE_THINKING=true

# crawl4ai browser settings.
DOMAIN_CRAWLER_BROWSER_TYPE=chromium
DOMAIN_CRAWLER_CHROME_CHANNEL=chromium
DOMAIN_CRAWLER_HEADLESS=true
DOMAIN_CRAWLER_LIGHT_MODE=true
DOMAIN_CRAWLER_USE_MANAGED_BROWSER=false
DOMAIN_CRAWLER_ENABLE_STEALTH=true

# Candidate filtering.
# If DOMAIN_SEARCH_EXCLUDED_DOMAINS is set, it replaces the built-in directory
# and registry exclusion list. Keep this commented out to use built-in defaults.
# DOMAIN_SEARCH_EXCLUDED_DOMAINS=proff.no,gulesider.no,brreg.no

# Additional domains to exclude on top of the active exclusion list.
DOMAIN_SEARCH_EXTRA_EXCLUDED_DOMAINS=

# Domains to allow even if they appear in the active exclusion list.
DOMAIN_SEARCH_ALLOWED_DOMAINS=
