# Temporal cluster gRPC address
TEMPORAL_HOST=localhost:7233

# corpscout PostgreSQL connection string (required)
CORPSCOUT_DB_URL=postgres://user:password@localhost:5435/corpscout?sslmode=disable

# Directory where per-run result JSON files are written (inside the container)
OUTPUT_DIR=/var/lib/data-pipelines/results

# Host path that is bind-mounted to OUTPUT_DIR inside the container
RESULTS_HOST_PATH=/var/lib/data-pipelines/results
