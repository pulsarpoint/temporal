# Corpscout Translation Service configuration.
#
# Copy this file to .env for local development. In Docker/production, pass the
# same variables through docker compose or the process environment.

# Default provider/model used when a request passes provider=default/model=default.
TRANSLATION_DEFAULT_PROVIDER=local
TRANSLATION_DEFAULT_MODEL=qwen3:6b

# Provider-specific OpenAI-compatible endpoint.
TRANSLATION_PROVIDER_LOCAL_BASE_URL=http://100.77.62.33:8888

# Optional. Leave empty for local LLM endpoints that do not require a key.
TRANSLATION_PROVIDER_LOCAL_API_KEY=

# Request timeout for LLM calls.
TRANSLATION_LLM_TIMEOUT_SECONDS=120
